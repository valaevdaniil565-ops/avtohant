DATABASE_URL=postgresql+psycopg://hunting:hunting@127.0.0.1:5432/hunting

# Telegram manager bot
BOT_TOKEN=
MANAGER_CHAT_IDS=
DIGEST_CHAT_IDS=
BOT_INGEST_CHAT_IDS=

# Telegram collector / Telethon
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=storage/sessions/collector
DOWNLOAD_DIR=storage
MAX_FILE_MB=20
BACKFILL_ENABLED=true
BACKFILL_LIMIT=200
BACKFILL_DAYS=7

# Collector routing modes
FORWARD_TO_BOT=false
FORWARD_BOT_USERNAME=
FORWARD_BOT_ID=
FORWARD_REPLY_TIMEOUT_SEC=60

ARCHIVE_ENABLED=false
ARCHIVE_CHAT_ID=
ARCHIVE_CHAT_USERNAME=
ARCHIVE_FAIL_OPEN=false

# Preferred backend-first ingest path
INGEST_VIA_DB_JOBS=true

# Collector rate limits
RL_BACKFILL_MIN_SEC=0.30
RL_FORWARD_MIN_SEC=0.80
RL_DOWNLOAD_MIN_SEC=0.50
RL_JITTER_SEC=0.40

# LLM / embeddings
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3:8b
EMBED_MODEL=nomic-embed-text
OLLAMA_HTTP_TIMEOUT_SEC=1200

# Matching and paging
TOP_K=10
MANUAL_TOP_K=100
MANUAL_PAGE_SIZE=10

# External source ingestion
ENABLE_EXTERNAL_LINK_INGEST=true
MCP_SOURCE_FETCHER_TRANSPORT=stdio
MCP_SOURCE_FETCHER_COMMAND=python -m app.integrations.mcp_source_fetcher.server
SOURCE_FETCHER_ALLOWED_DOMAINS=docs.google.com,drive.google.com,disk.yandex.ru,disk.360.yandex.ru,yadi.sk,storage.googleapis.com,raw.githubusercontent.com
SOURCE_FETCHER_TIMEOUT_S=1200
SOURCE_FETCHER_MAX_BYTES=5000000
SOURCE_FETCHER_MAX_ITEMS=200

# Background jobs
JOBS_ENABLED=true
JOB_WORKER_ID=local-worker-1
JOB_WORKER_POLL_SEC=3
JOB_SCHEDULER_POLL_SEC=30

# Own bench / partner sync
PARTNER_COMPANIES_SOURCE_URL=
OWN_BENCH_SYNC_INTERVAL_MIN=240
PARTNER_COMPANIES_SYNC_INTERVAL_MIN=720

# Digest background job
DIGEST_JOB_ENABLED=true
DIGEST_SCHEDULE_HOUR=16
DIGEST_SCHEDULE_MINUTE=0
DIGEST_DELIVERY_ENABLED=false

# Optional future extension for private Google access
GOOGLE_SERVICE_ACCOUNT_JSON=
